generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum AccountSource {
  PORTAL
  ADMIN
}

enum ProductType {
  READY_MAP
  CUSTOM_TUNE
  SERVICE
}

enum OrderStatus {
  AWAITING_PAYMENT
  PAID
  FILE_RECEIVED
  IN_PROGRESS
  READY_FOR_DOWNLOAD
  COMPLETED
  CANCELLED
}

enum CancelledBy {
  CUSTOMER
  ADMIN
}

enum NotificationType {
  ORDER_SUBMITTED
  PAYMENT_UPLOADED
  TUNED_FILE_READY
  PAYMENT_CONFIRMED
  REVISION_READY
}

enum TuningType {
  ECU
  TCU
  ECU_TCU
}

enum OrderType {
  STANDARD_TUNING
  CUSTOM_ORDER
}

enum OrderSource {
  ONLINE_PORTAL
  ADMIN_PORTAL
}

enum DocType {
  CS
  INV
}

enum TaxCalculationMethod {
  EXCLUSIVE
  INCLUSIVE
}

enum TaxCalculationMode {
  TRANSACTION
  LINE_ITEM
}

model User {
  id                 String         @id @default(cuid())
  name               String
  email              String         @unique
  passwordHash       String
  role               Role           @default(CUSTOMER)
  phone              String?        @unique
  accountSource      AccountSource  @default(PORTAL)
  portalAccess       Boolean        @default(true)
  resetToken         String?
  resetTokenExpiry   DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  orders             Order[]        @relation("CustomerOrders")
  adminCreatedOrders      Order[]        @relation("AdminCreatedOrders")
  creditNotes            CreditNote[]    @relation("CustomerCreditNotes")
  adminCreatedCreditNotes CreditNote[]   @relation("AdminCreatedCreditNotes")
  notifications          Notification[]
}

model VehicleBrand {
  id     String         @id @default(cuid())
  name   String
  slug   String         @unique
  models VehicleModel[]
}

model VehicleModel {
  id      String        @id @default(cuid())
  name    String
  slug    String
  brandId String
  brand   VehicleBrand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  years   VehicleYear[]

  @@unique([brandId, slug])
}

model VehicleYear {
  id      String       @id @default(cuid())
  year    Int
  modelId String
  model   VehicleModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  ecus    EcuType[]

  @@unique([modelId, year])
}

model EcuType {
  id            String      @id @default(cuid())
  name          String
  manufacturer  String?
  protocol      String?
  vehicleYearId String
  vehicleYear   VehicleYear @relation(fields: [vehicleYearId], references: [id], onDelete: Cascade)
}

model Product {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String
  type        ProductType
  basePrice   Int
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model TaxCode {
  id                       String               @id @default(cuid())
  code                     String               @unique
  description              String
  displayLabel             String?
  rate                     Decimal              @db.Decimal(5, 2)
  calculationMethod        TaxCalculationMethod
  isActive                 Boolean              @default(true)
  sortOrder                Int                  @default(0)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  defaultPortalForConfigs  TaxConfiguration[]   @relation("DefaultPortalTaxCode")
  defaultAdminForConfigs   TaxConfiguration[]   @relation("DefaultAdminTaxCode")
  customOrderItems         CustomOrderItem[]

  @@index([isActive, sortOrder, code])
}

model TaxConfiguration {
  id                     String             @id
  taxModuleEnabled       Boolean            @default(false)
  taxCalculationMode     TaxCalculationMode @default(TRANSACTION)
  defaultPortalTaxCodeId String?
  defaultAdminTaxCodeId  String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  defaultPortalTaxCode   TaxCode?           @relation("DefaultPortalTaxCode", fields: [defaultPortalTaxCodeId], references: [id], onDelete: SetNull)
  defaultAdminTaxCode    TaxCode?           @relation("DefaultAdminTaxCode", fields: [defaultAdminTaxCodeId], references: [id], onDelete: SetNull)

  @@index([defaultPortalTaxCodeId])
  @@index([defaultAdminTaxCodeId])
}

model Order {
  id                     String            @id @default(cuid())
  orderNumber            String            @unique
  status                 OrderStatus       @default(AWAITING_PAYMENT)
  orderType              OrderType         @default(STANDARD_TUNING)
  source                 OrderSource       @default(ONLINE_PORTAL)
  docType                DocType?
  notes                  String?
  requestDetails         String?
  tuningType             TuningType        @default(ECU)
  selectedTuneId         String?
  selectedTuneLabel      String?
  ecuStage               String?
  tcuStage               String?
  vehicleBrand           String?
  vehicleModel           String?
  engineModel            String?
  engineCapacity         String?
  vehicleYear            String?
  vehicleNo              String?
  ecuType                String?
  ecuReadTool            String?
  fuelGrade              String?
  waterMethanolInjection String?
  currentEcuSetupStage   String?
  turboType              String?
  turboSpec              String?
  hardwareMods           String?
  fuelSystemMods         String?
  engineMods             String?
  engineModsOther        String?
  additionalDetails      String?
  tcuType                String?
  tcuVersion             String?
  tcuReadTool            String?
  customTitle            String?
  internalRemarks        String?
  documentDate           DateTime          @default(now())
  customSubtotal         Decimal           @default(0) @db.Decimal(12, 2)
  customDiscount         Decimal           @default(0) @db.Decimal(12, 2)
  customGrandTotal       Decimal           @default(0) @db.Decimal(12, 2)
  taxCodeId              String?
  taxCode                String?
  taxDescription         String?
  taxDisplayLabel        String?
  taxRate                Decimal?          @db.Decimal(5, 2)
  taxCalculationMethod   TaxCalculationMethod?
  taxAmount              Decimal           @default(0) @db.Decimal(12, 2)
  taxableSubtotal        Decimal           @default(0) @db.Decimal(12, 2)
  grandTotalAfterTax     Decimal           @default(0) @db.Decimal(12, 2)
  isTaxEnabledSnapshot   Boolean           @default(false)
  cancelledBy            CancelledBy?
  cancelReason           String?
  cancelledAt            DateTime?
  totalAmount            Decimal           @default(0) @db.Decimal(12, 2)
  totalPaid              Decimal           @default(0) @db.Decimal(12, 2)
  outstandingBalance     Decimal           @default(0) @db.Decimal(12, 2)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  userId                 String
  createdByAdminId       String?
  user                   User              @relation("CustomerOrders", fields: [userId], references: [id], onDelete: Cascade)
  createdByAdmin         User?             @relation("AdminCreatedOrders", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  items                  OrderItem[]
  customItems            CustomOrderItem[]
  files                  OrderFile[]
  revisions              OrderRevision[]
  notifications          Notification[]
  payments               Payment[]
  creditNote             CreditNote?

  @@index([createdByAdminId])
  @@index([orderType])
  @@index([source])
  @@index([docType])
  @@index([taxCode])
}

model OrderItem {
  id        String  @id @default(cuid())
  price     Int
  quantity  Int     @default(1)
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model CustomOrderItem {
  id          String   @id @default(cuid())
  orderId      String
  description  String
  qty          Int      @default(1)
  uom          String?
  unitPrice    Decimal  @db.Decimal(12, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)
  taxCodeId    String?
  taxCode      String?
  taxRate      Decimal? @db.Decimal(5, 2)
  taxAmount    Decimal  @default(0) @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  taxCodeRef   TaxCode? @relation(fields: [taxCodeId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([taxCodeId])
  @@index([taxCode])
}


model Payment {
  id          String   @id @default(cuid())
  orderId     String
  paymentDate DateTime
  paymentMode String
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([paymentDate])
}

model OrderFile {
  id          String         @id @default(cuid())
  orderId     String
  kind        String
  fileName    String
  storagePath String
  mimeType    String?
  createdAt   DateTime       @default(now())
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  revision    OrderRevision?
}

model OrderRevision {
  id             String   @id @default(cuid())
  orderId        String
  orderFileId    String   @unique
  revisionNo     Int
  revisionTarget String?
  remark         String
  createdAt      DateTime @default(now())

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderFile OrderFile @relation(fields: [orderFileId], references: [id], onDelete: Cascade)

  @@unique([orderId, revisionNo, revisionTarget])
  @@index([orderId, createdAt])
}


model CreditNote {
  id                   String           @id @default(cuid())
  cnNo                 String           @unique
  cnDate               DateTime         @default(now())
  orderId              String           @unique
  customerId           String
  referenceOrderNumber String
  reasonType           String
  reasonRemarks        String?
  amount               Int
  createdByAdminId     String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  order                Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer             User             @relation("CustomerCreditNotes", fields: [customerId], references: [id], onDelete: Cascade)
  createdByAdmin       User             @relation("AdminCreatedCreditNotes", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  items                CreditNoteItem[]

  @@index([customerId])
  @@index([createdByAdminId])
  @@index([cnDate])
}

model CreditNoteItem {
  id           String     @id @default(cuid())
  creditNoteId String
  description  String
  qty          Int        @default(1)
  uom          String?
  unitPrice    Decimal  @db.Decimal(12, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  orderId   String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  readAt    DateTime?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([orderId, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String?
  userName    String?
  userEmail   String?
  userRole    String?
  module      String
  action      String
  entityType  String?
  entityId    String?
  entityCode  String?
  description String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  location    String?
  userAgent   String?
  status      String
  requestId   String?

  @@index([createdAt])
  @@index([module, action])
  @@index([status, createdAt])
  @@index([entityType, entityId])
  @@index([userEmail, createdAt])
}
