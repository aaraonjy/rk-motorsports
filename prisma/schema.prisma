generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum AccountSource {
  PORTAL
  ADMIN
}

enum CustomerAccountNoFormat {
  XXXX_XXXX
  XXXX_XXXXX
  XXXX_XXX
  XXX_XXXX
}

enum CustomerRegistrationIdType {
  BRN
  NRIC
  PASSPORT
  ARMY
}

enum ProductType {
  READY_MAP
  CUSTOM_TUNE
  SERVICE
}

enum OrderStatus {
  AWAITING_PAYMENT
  PAID
  FILE_RECEIVED
  IN_PROGRESS
  READY_FOR_DOWNLOAD
  COMPLETED
  CANCELLED
}

enum CancelledBy {
  CUSTOMER
  ADMIN
}

enum NotificationType {
  ORDER_SUBMITTED
  PAYMENT_UPLOADED
  TUNED_FILE_READY
  PAYMENT_CONFIRMED
  REVISION_READY
}

enum TuningType {
  ECU
  TCU
  ECU_TCU
}

enum OrderType {
  STANDARD_TUNING
  CUSTOM_ORDER
}

enum OrderSource {
  ONLINE_PORTAL
  ADMIN_PORTAL
}

enum DocType {
  CS
  INV
}

enum SalesDocType {
  QO
  SO
  DO
  INV
  CS
  CN
  DN
  DR
}

enum SalesTransactionStatus {
  PENDING
  OPEN
  CONFIRMED
  PARTIAL
  COMPLETED
  INVOICED
  POSTED
  CANCELLED
}

enum SalesLinkType {
  GENERATED_FROM
  GENERATED_TO
}

enum TaxCalculationMethod {
  EXCLUSIVE
  INCLUSIVE
}

enum TaxCalculationMode {
  TRANSACTION
  LINE_ITEM
}

enum TaxType {
  SALES
  SERVICE
}

enum InventoryItemType {
  STOCK_ITEM
  SERVICE_ITEM
  NON_STOCK_ITEM
}

enum StockCostingMethod {
  AVERAGE
}

enum StockTransactionType {
  OB
  SR
  SI
  SA
  ST
  AS
}

enum StockTransactionStatus {
  POSTED
  CANCELLED
}

enum StockMovementDirection {
  IN
  OUT
}

enum StockAdjustmentDirection {
  IN
  OUT
}

enum InventorySerialStatus {
  IN_STOCK
  OUT_OF_STOCK
}


model User {
  id                     String              @id @default(cuid())
  name                   String
  email                  String              @unique
  passwordHash           String
  role                   Role                @default(CUSTOMER)
  phone                  String?             @unique
  phone2                 String?
  fax                    String?
  customerAccountNo      String?             @unique
  accountSource          AccountSource       @default(PORTAL)
  portalAccess           Boolean             @default(true)
  billingAddressLine1    String?
  billingAddressLine2    String?
  billingAddressLine3    String?
  billingAddressLine4    String?
  billingCity            String?
  billingPostCode        String?
  billingCountryCode     String?
  deliveryAddressLine1   String?
  deliveryAddressLine2   String?
  deliveryAddressLine3   String?
  deliveryAddressLine4   String?
  deliveryCity           String?
  deliveryPostCode       String?
  deliveryCountryCode    String?
  area                   String?
  attention              String?
  contactPerson          String?
  emailCc                String?
  currency               String              @default("MYR")
  agentId                String?
  natureOfBusiness       String?
  registrationIdType     CustomerRegistrationIdType?
  registrationNo         String?
  taxIdentificationNo    String?
  resetToken             String?
  resetTokenExpiry       DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  orders                 Order[]             @relation("CustomerOrders")
  adminCreatedOrders     Order[]             @relation("AdminCreatedOrders")
  creditNotes            CreditNote[]        @relation("CustomerCreditNotes")
  adminCreatedCreditNotes CreditNote[]       @relation("AdminCreatedCreditNotes")
  customerSalesTransactions SalesTransaction[] @relation("CustomerSalesTransactions")
  notifications           Notification[]
  createdStockTransactions StockTransaction[] @relation("CreatedStockTransactions")
  cancelledStockTransactions StockTransaction[] @relation("CancelledStockTransactions")
  createdSalesTransactions SalesTransaction[] @relation("CreatedSalesTransactions")
  cancelledSalesTransactions SalesTransaction[] @relation("CancelledSalesTransactions")
  agent                  Agent?              @relation(fields: [agentId], references: [id], onDelete: SetNull)
  deliveryAddresses      CustomerDeliveryAddress[]

  @@index([agentId])
}

model VehicleBrand {
  id     String         @id @default(cuid())
  name   String
  slug   String         @unique
  models VehicleModel[]
}

model VehicleModel {
  id      String        @id @default(cuid())
  name    String
  slug    String
  brandId String
  brand   VehicleBrand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  years   VehicleYear[]

  @@unique([brandId, slug])
}

model VehicleYear {
  id      String       @id @default(cuid())
  year    Int
  modelId String
  model   VehicleModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  ecus    EcuType[]

  @@unique([modelId, year])
}

model EcuType {
  id            String      @id @default(cuid())
  name          String
  manufacturer  String?
  protocol      String?
  vehicleYearId String
  vehicleYear   VehicleYear @relation(fields: [vehicleYearId], references: [id], onDelete: Cascade)
}

model Product {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String
  type        ProductType
  basePrice   Int
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model TaxCode {
  id                       String               @id @default(cuid())
  code                     String               @unique
  description              String
  displayLabel             String?
  rate                     Decimal              @db.Decimal(5, 2)
  calculationMethod        TaxCalculationMethod
  taxType                  TaxType               @default(SERVICE)
  isActive                 Boolean              @default(true)
  sortOrder                Int                  @default(0)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  defaultPortalForConfigs  TaxConfiguration[]   @relation("DefaultPortalTaxCode")
  defaultAdminForConfigs   TaxConfiguration[]   @relation("DefaultAdminTaxCode")
  customOrderItems         CustomOrderItem[]

  @@index([isActive, sortOrder, code])
}

model TaxConfiguration {
  id                     String             @id
  taxModuleEnabled       Boolean            @default(false)
  taxCalculationMode     TaxCalculationMode @default(TRANSACTION)
  defaultPortalTaxCodeId String?
  defaultAdminTaxCodeId  String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  defaultPortalTaxCode   TaxCode?           @relation("DefaultPortalTaxCode", fields: [defaultPortalTaxCodeId], references: [id], onDelete: SetNull)
  defaultAdminTaxCode    TaxCode?           @relation("DefaultAdminTaxCode", fields: [defaultAdminTaxCodeId], references: [id], onDelete: SetNull)

  @@index([defaultPortalTaxCodeId])
  @@index([defaultAdminTaxCodeId])
}

model AccountConfiguration {
  id                       String                  @id
  customerAccountPrefix    String                  @default("3000")
  customerAccountNoFormat  CustomerAccountNoFormat @default(XXXX_XXXX)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
}


model StockConfiguration {
  id                    String             @id
  stockModuleEnabled    Boolean            @default(false)
  multiLocationEnabled  Boolean            @default(false)
  allowNegativeStock    Boolean            @default(false)
  enableProject         Boolean            @default(false)
  enableDepartment      Boolean            @default(false)
  costingMethod         StockCostingMethod @default(AVERAGE)
  multiUomEnabled       Boolean            @default(false)
  serialTrackingEnabled Boolean            @default(false)
  batchTrackingEnabled  Boolean            @default(false)
  defaultLocationId     String?
  qtyDecimalPlaces      Int                @default(0)
  unitCostDecimalPlaces Int                @default(2)
  priceDecimalPlaces    Int                @default(2)
  allowDocNoOverrideOB  Boolean            @default(false)
  allowDocNoOverrideSR  Boolean            @default(false)
  allowDocNoOverrideSI  Boolean            @default(false)
  allowDocNoOverrideSA  Boolean            @default(false)
  allowDocNoOverrideST  Boolean            @default(false)
  allowDocNoOverrideAS  Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  defaultLocation       StockLocation?     @relation(fields: [defaultLocationId], references: [id], onDelete: SetNull)

  @@index([defaultLocationId])
}

model StockLocation {
  id                           String                 @id @default(cuid())
  code                         String                 @unique
  name                         String
  isActive                     Boolean                @default(true)
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  defaultForConfigs            StockConfiguration[]
  inventoryProducts            InventoryProduct[]
  transactionLines             StockTransactionLine[] @relation("StockTransactionLineLocation")
  transferFromLines            StockTransactionLine[] @relation("StockTransactionLineFromLocation")
  transferToLines              StockTransactionLine[] @relation("StockTransactionLineToLocation")
  ledgerEntries                StockLedger[]          @relation("StockLedgerLocation")
  inventorySerials             InventorySerial[]      @relation("InventorySerialCurrentLocation")
}


model InventoryProduct {
  id                   String                 @id @default(cuid())
  code                 String                 @unique
  description          String
  group                String?
  subGroup             String?
  brand                String?
  groupId              String?
  subGroupId           String?
  brandId              String?
  itemType             InventoryItemType
  baseUom              String
  unitCost             Decimal                @default(0) @db.Decimal(12, 3)
  sellingPrice         Decimal                @default(0) @db.Decimal(12, 3)
  trackInventory       Boolean                @default(false)
  serialNumberTracking Boolean                @default(false)
  batchTracking        Boolean                @default(false)
  isAssemblyItem       Boolean                @default(false)
  isActive             Boolean                @default(true)
  defaultLocationId    String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  defaultLocation      StockLocation?         @relation(fields: [defaultLocationId], references: [id], onDelete: SetNull)
  productGroup         ProductGroup?          @relation(fields: [groupId], references: [id], onDelete: SetNull)
  productSubGroup      ProductSubGroup?       @relation(fields: [subGroupId], references: [id], onDelete: SetNull)
  productBrand         ProductBrand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  customOrderItems     CustomOrderItem[]
  stockTransactionLines StockTransactionLine[]
  salesTransactionLines SalesTransactionLine[]
  stockLedgerEntries   StockLedger[]
  batches              InventoryBatch[]
  serials              InventorySerial[]
  serialTransactionEntries StockTransactionLineSerial[]
  uomConversions       InventoryProductUomConversion[]
  assemblyTemplates    AssemblyTemplate[]    @relation("AssemblyTemplateFinishedGood")
  assemblyComponentLines AssemblyTemplateLine[] @relation("AssemblyTemplateComponentProduct")

  @@index([isActive, code])
  @@index([itemType, isActive])
  @@index([isAssemblyItem])
  @@index([defaultLocationId])
  @@index([groupId])
  @@index([subGroupId])
  @@index([brandId])
}




model AssemblyTemplate {
  id                    String                 @id @default(cuid())
  finishedGoodProductId String                 @unique
  isActive              Boolean                @default(true)
  remarks               String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  finishedGoodProduct   InventoryProduct       @relation("AssemblyTemplateFinishedGood", fields: [finishedGoodProductId], references: [id], onDelete: Cascade)
  lines                 AssemblyTemplateLine[]

  @@index([isActive])
}

model AssemblyTemplateLine {
  id                  String            @id @default(cuid())
  assemblyTemplateId  String
  lineNo              Int
  componentProductId  String
  qty                 Decimal           @db.Decimal(12, 3)
  uom                 String
  isRequired          Boolean           @default(true)
  allowOverride       Boolean           @default(false)
  remarks             String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  assemblyTemplate    AssemblyTemplate  @relation(fields: [assemblyTemplateId], references: [id], onDelete: Cascade)
  componentProduct    InventoryProduct  @relation("AssemblyTemplateComponentProduct", fields: [componentProductId], references: [id], onDelete: Restrict)

  @@unique([assemblyTemplateId, lineNo])
  @@index([assemblyTemplateId])
  @@index([componentProductId])
}

model InventoryProductUomConversion {
  id                 String            @id @default(cuid())
  inventoryProductId String
  uomCode            String
  conversionRate     Decimal           @db.Decimal(12, 4)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  inventoryProduct   InventoryProduct  @relation(fields: [inventoryProductId], references: [id], onDelete: Cascade)

  @@unique([inventoryProductId, uomCode])
  @@index([inventoryProductId])
}

model InventoryBatch {
  id                 String   @id @default(cuid())
  inventoryProductId String
  batchNo            String
  expiryDate         DateTime?
  isArchived         Boolean  @default(false)
  archivedAt         DateTime?
  archivedByAdminId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt

  inventoryProduct InventoryProduct @relation(fields: [inventoryProductId], references: [id], onDelete: Cascade)
  serials          InventorySerial[]
  lineSerials      StockTransactionLineSerial[]

  @@unique([inventoryProductId, batchNo])
  @@index([inventoryProductId])
  @@index([isArchived, inventoryProductId])
}

model ProductGroup {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  subGroups   ProductSubGroup[]
  products    InventoryProduct[]

  @@index([isActive, code])
  @@index([name])
}

model ProductSubGroup {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  groupId     String
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  group       ProductGroup      @relation(fields: [groupId], references: [id], onDelete: Restrict)
  products    InventoryProduct[]

  @@index([groupId, isActive])
  @@index([name])
}

model ProductBrand {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  products    InventoryProduct[]

  @@index([isActive, code])
  @@index([name])
}

model Project {
  id                String             @id @default(cuid())
  code              String             @unique
  name              String
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  departments       Department[]
  stockTransactions StockTransaction[]
  salesTransactions SalesTransaction[]

  @@index([isActive, code])
  @@index([name])
}


model Agent {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  customers User[]
  salesTransactions SalesTransaction[]

  @@index([isActive, code])
  @@index([name])
}

model CustomerDeliveryAddress {
  id           String   @id @default(cuid())
  customerId   String
  label        String?
  addressLine1 String
  addressLine2 String?
  addressLine3 String?
  addressLine4 String?
  city         String?
  postCode     String?
  countryCode  String?  @default("MY")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customer     User     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}


model SalesTransaction {
  id                   String                 @id @default(cuid())
  docType              SalesDocType
  docNo                String                 @unique
  docDate              DateTime               @default(now())
  docDesc              String?
  status               SalesTransactionStatus @default(PENDING)
  customerId           String
  customerAccountNo    String?
  customerName         String
  billingAddressLine1  String?
  billingAddressLine2  String?
  billingAddressLine3  String?
  billingAddressLine4  String?
  billingCity          String?
  billingPostCode      String?
  billingCountryCode   String?
  deliveryAddressLine1 String?
  deliveryAddressLine2 String?
  deliveryAddressLine3 String?
  deliveryAddressLine4 String?
  deliveryCity         String?
  deliveryPostCode     String?
  deliveryCountryCode  String?
  attention            String?
  contactNo            String?
  email                String?
  currency             String                 @default("MYR")
  reference            String?
  remarks              String?
  agentId              String?
  projectId            String?
  departmentId         String?
  subtotal             Decimal                @default(0) @db.Decimal(14, 2)
  discountTotal        Decimal                @default(0) @db.Decimal(14, 2)
  taxableSubtotal      Decimal                @default(0) @db.Decimal(14, 2)
  taxCodeId            String?
  taxCode              String?
  taxDescription       String?
  taxDisplayLabel      String?
  taxRate              Decimal?               @db.Decimal(5, 2)
  taxCalculationMethod TaxCalculationMethod?
  taxCalculationModeSnapshot TaxCalculationMode @default(TRANSACTION)
  isTaxEnabledSnapshot Boolean                @default(false)
  taxTotal             Decimal                @default(0) @db.Decimal(14, 2)
  grandTotal           Decimal                @default(0) @db.Decimal(14, 2)
  termsAndConditions   String?
  bankAccount          String?
  footerRemarks        String?
  createdByAdminId     String
  cancelledByAdminId   String?
  cancelReason         String?
  cancelledAt          DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  customer             User                   @relation("CustomerSalesTransactions", fields: [customerId], references: [id], onDelete: Restrict)
  agent                Agent?                 @relation(fields: [agentId], references: [id], onDelete: SetNull)
  project              Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  department           Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdByAdmin       User                   @relation("CreatedSalesTransactions", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  cancelledByAdmin     User?                  @relation("CancelledSalesTransactions", fields: [cancelledByAdminId], references: [id], onDelete: SetNull)
  lines                SalesTransactionLine[]
  sourceLinks          SalesTransactionLink[] @relation("SalesTransactionSourceLinks")
  targetLinks          SalesTransactionLink[] @relation("SalesTransactionTargetLinks")

  @@index([docType, docDate])
  @@index([status, docDate])
  @@index([customerId, docDate])
  @@index([createdByAdminId, createdAt])
  @@index([cancelledByAdminId])
  @@index([agentId])
  @@index([projectId])
  @@index([departmentId])
  @@index([taxCodeId])
}

model SalesTransactionLine {
  id                  String            @id @default(cuid())
  transactionId       String
  lineNo              Int
  inventoryProductId  String?
  productCode         String
  productDescription  String
  uom                 String
  qty                 Decimal           @db.Decimal(12, 3)
  unitPrice           Decimal           @db.Decimal(14, 2)
  discountRate        Decimal           @default(0) @db.Decimal(5, 2)
  discountType        String            @default("PERCENT")
  discountAmount      Decimal           @default(0) @db.Decimal(14, 2)
  locationId          String?
  locationCode        String?
  locationName        String?
  taxCodeId           String?
  taxCode             String?
  taxDescription      String?
  taxDisplayLabel     String?
  taxRate             Decimal           @default(0) @db.Decimal(5, 2)
  taxCalculationMethod TaxCalculationMethod?
  taxAmount           Decimal           @default(0) @db.Decimal(14, 2)
  lineSubtotal        Decimal           @default(0) @db.Decimal(14, 2)
  lineTotal           Decimal           @default(0) @db.Decimal(14, 2)
  remarks             String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  transaction         SalesTransaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  inventoryProduct    InventoryProduct? @relation(fields: [inventoryProductId], references: [id], onDelete: SetNull)

  @@unique([transactionId, lineNo])
  @@index([transactionId])
  @@index([inventoryProductId])
  @@index([locationId])
  @@index([taxCodeId])
}

model SalesTransactionLink {
  id                  String           @id @default(cuid())
  sourceTransactionId String
  targetTransactionId String
  linkType            SalesLinkType
  createdAt           DateTime         @default(now())

  sourceTransaction   SalesTransaction @relation("SalesTransactionSourceLinks", fields: [sourceTransactionId], references: [id], onDelete: Cascade)
  targetTransaction   SalesTransaction @relation("SalesTransactionTargetLinks", fields: [targetTransactionId], references: [id], onDelete: Cascade)

  @@unique([sourceTransactionId, targetTransactionId, linkType])
  @@index([sourceTransactionId])
  @@index([targetTransactionId])
}

model Department {
  id                String             @id @default(cuid())
  code              String             @unique
  name              String
  projectId         String
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  project           Project            @relation(fields: [projectId], references: [id], onDelete: Restrict)
  stockTransactions StockTransaction[]
  salesTransactions SalesTransaction[]

  @@index([projectId, isActive])
  @@index([name])
}

model Order {
  id                     String            @id @default(cuid())
  orderNumber            String            @unique
  status                 OrderStatus       @default(AWAITING_PAYMENT)
  orderType              OrderType         @default(STANDARD_TUNING)
  source                 OrderSource       @default(ONLINE_PORTAL)
  docType                DocType?
  notes                  String?
  requestDetails         String?
  tuningType             TuningType        @default(ECU)
  selectedTuneId         String?
  selectedTuneLabel      String?
  ecuStage               String?
  tcuStage               String?
  vehicleBrand           String?
  vehicleModel           String?
  engineModel            String?
  engineCapacity         String?
  vehicleYear            String?
  vehicleNo              String?
  ecuType                String?
  ecuReadTool            String?
  fuelGrade              String?
  waterMethanolInjection String?
  currentEcuSetupStage   String?
  turboType              String?
  turboSpec              String?
  hardwareMods           String?
  fuelSystemMods         String?
  engineMods             String?
  engineModsOther        String?
  additionalDetails      String?
  tcuType                String?
  tcuVersion             String?
  tcuReadTool            String?
  customTitle            String?
  internalRemarks        String?
  documentDate           DateTime          @default(now())
  customSubtotal         Decimal           @default(0) @db.Decimal(12, 2)
  customDiscount         Decimal           @default(0) @db.Decimal(12, 2)
  customGrandTotal       Decimal           @default(0) @db.Decimal(12, 2)
  taxCodeId              String?
  taxCode                String?
  taxDescription         String?
  taxDisplayLabel        String?
  taxRate                Decimal?          @db.Decimal(5, 2)
  taxCalculationMethod   TaxCalculationMethod?
  taxAmount              Decimal           @default(0) @db.Decimal(12, 2)
  taxableSubtotal        Decimal           @default(0) @db.Decimal(12, 2)
  grandTotalAfterTax     Decimal           @default(0) @db.Decimal(12, 2)
  isTaxEnabledSnapshot   Boolean           @default(false)
  cancelledBy            CancelledBy?
  cancelReason           String?
  cancelledAt            DateTime?
  totalAmount            Decimal           @default(0) @db.Decimal(12, 2)
  totalPaid              Decimal           @default(0) @db.Decimal(12, 2)
  outstandingBalance     Decimal           @default(0) @db.Decimal(12, 2)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  userId                 String
  createdByAdminId       String?
  user                   User              @relation("CustomerOrders", fields: [userId], references: [id], onDelete: Cascade)
  createdByAdmin         User?             @relation("AdminCreatedOrders", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  items                  OrderItem[]
  customItems            CustomOrderItem[]
  files                  OrderFile[]
  revisions              OrderRevision[]
  notifications          Notification[]
  payments               Payment[]
  creditNote             CreditNote?

  @@index([createdByAdminId])
  @@index([orderType])
  @@index([source])
  @@index([docType])
  @@index([taxCode])
}

model OrderItem {
  id        String  @id @default(cuid())
  price     Int
  quantity  Int     @default(1)
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model CustomOrderItem {
  id                  String             @id @default(cuid())
  orderId             String
  inventoryProductId  String?
  productCodeSnapshot String?
  itemTypeSnapshot    InventoryItemType?
  description         String
  qty                 Int                @default(1)
  uom                 String?
  unitPrice           Decimal            @db.Decimal(12, 2)
  lineTotal           Decimal            @db.Decimal(12, 2)
  locationId          String?
  locationCode        String?
  locationName        String?
  taxCodeId           String?
  taxCode             String?
  taxRate             Decimal?           @db.Decimal(5, 2)
  taxAmount           Decimal            @default(0) @db.Decimal(12, 2)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  order               Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventoryProduct    InventoryProduct?  @relation(fields: [inventoryProductId], references: [id], onDelete: SetNull)
  taxCodeRef          TaxCode?           @relation(fields: [taxCodeId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([inventoryProductId])
  @@index([productCodeSnapshot])
  @@index([taxCodeId])
  @@index([taxCode])
}


model Payment {
  id          String   @id @default(cuid())
  orderId     String
  paymentDate DateTime
  paymentMode String
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([paymentDate])
}

model OrderFile {
  id          String         @id @default(cuid())
  orderId     String
  kind        String
  fileName    String
  storagePath String
  mimeType    String?
  createdAt   DateTime       @default(now())
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  revision    OrderRevision?
}

model OrderRevision {
  id             String   @id @default(cuid())
  orderId        String
  orderFileId    String   @unique
  revisionNo     Int
  revisionTarget String?
  remark         String
  createdAt      DateTime @default(now())

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderFile OrderFile @relation(fields: [orderFileId], references: [id], onDelete: Cascade)

  @@unique([orderId, revisionNo, revisionTarget])
  @@index([orderId, createdAt])
}


model CreditNote {
  id                   String           @id @default(cuid())
  cnNo                 String           @unique
  cnDate               DateTime         @default(now())
  orderId              String           @unique
  customerId           String
  referenceOrderNumber String
  reasonType           String
  reasonRemarks        String?
  amount               Int
  createdByAdminId     String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  order                Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer             User             @relation("CustomerCreditNotes", fields: [customerId], references: [id], onDelete: Cascade)
  createdByAdmin       User             @relation("AdminCreatedCreditNotes", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  items                CreditNoteItem[]

  @@index([customerId])
  @@index([createdByAdminId])
  @@index([cnDate])
}

model CreditNoteItem {
  id           String     @id @default(cuid())
  creditNoteId String
  description  String
  qty          Int        @default(1)
  uom          String?
  unitPrice    Decimal    @db.Decimal(12, 2)
  lineTotal    Decimal    @db.Decimal(12, 2)
  taxCodeId    String?
  taxCode      String?
  taxRate      Decimal?   @db.Decimal(5, 2)
  taxAmount    Decimal    @default(0) @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
  @@index([taxCodeId])
  @@index([taxCode])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  orderId   String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  readAt    DateTime?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([orderId, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String?
  userName    String?
  userEmail   String?
  userRole    String?
  module      String
  action      String
  entityType  String?
  entityId    String?
  entityCode  String?
  description String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  location    String?
  userAgent   String?
  status      String
  requestId   String?

  @@index([createdAt])
  @@index([module, action])
  @@index([status, createdAt])
  @@index([entityType, entityId])
  @@index([userEmail, createdAt])
}


model StockTransaction {
  id                 String                 @id @default(cuid())
  transactionNo      String                 @unique
  transactionType    StockTransactionType
  transactionDate    DateTime
  docNo              String?                @unique
  docDate            DateTime               @default(now())
  docDesc            String?
  projectId          String?
  departmentId       String?
  reference          String?
  remarks            String?
  status             StockTransactionStatus @default(POSTED)
  createdByAdminId   String
  cancelledByAdminId String?
  revisedFromId      String?
  cancelReason       String?
  cancelledAt        DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  createdByAdmin     User                   @relation("CreatedStockTransactions", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  cancelledByAdmin   User?                  @relation("CancelledStockTransactions", fields: [cancelledByAdminId], references: [id], onDelete: SetNull)
  revisedFrom        StockTransaction?      @relation("StockTransactionRevisions", fields: [revisedFromId], references: [id], onDelete: SetNull)
  revisions          StockTransaction[]     @relation("StockTransactionRevisions")
  project            Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  department         Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  lines              StockTransactionLine[]
  ledgerEntries      StockLedger[]

  @@index([transactionType, transactionDate])
  @@index([createdByAdminId, createdAt])
  @@index([status, transactionDate])
  @@index([cancelledByAdminId])
  @@index([revisedFromId])
  @@index([status, cancelledAt])
}

model StockTransactionLine {
  id                  String                   @id @default(cuid())
  transactionId       String
  inventoryProductId  String
  qty                 Decimal                  @db.Decimal(12, 3)
  unitCost            Decimal?                 @db.Decimal(12, 3)
  batchNo             String?
  expiryDate          DateTime?
  remarks             String?
  locationId          String?
  fromLocationId      String?
  toLocationId        String?
  adjustmentDirection StockAdjustmentDirection?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  transaction         StockTransaction         @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  inventoryProduct    InventoryProduct         @relation(fields: [inventoryProductId], references: [id], onDelete: Restrict)
  location            StockLocation?           @relation("StockTransactionLineLocation", fields: [locationId], references: [id], onDelete: SetNull)
  fromLocation        StockLocation?           @relation("StockTransactionLineFromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocation          StockLocation?           @relation("StockTransactionLineToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  ledgerEntries       StockLedger[]
  serialEntries       StockTransactionLineSerial[]

  @@index([transactionId])
  @@index([inventoryProductId])
  @@index([locationId])
  @@index([fromLocationId])
  @@index([toLocationId])
}

model StockLedger {
  id                String                 @id @default(cuid())
  movementDate      DateTime
  movementType      StockTransactionType
  movementDirection StockMovementDirection
  qty               Decimal                @db.Decimal(12, 3)
  qtyIn             Decimal                @default(0) @db.Decimal(12, 3)
  qtyOut            Decimal                @default(0) @db.Decimal(12, 3)
  batchNo            String?
  inventoryProductId String
  locationId        String
  transactionId     String?
  transactionLineId String?
  referenceNo       String?
  referenceText     String?
  sourceType        String?
  sourceId          String?
  remarks           String?
  createdAt         DateTime               @default(now())
  inventoryProduct  InventoryProduct       @relation(fields: [inventoryProductId], references: [id], onDelete: Restrict)
  location          StockLocation          @relation("StockLedgerLocation", fields: [locationId], references: [id], onDelete: Restrict)
  transaction       StockTransaction?      @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  transactionLine   StockTransactionLine?  @relation(fields: [transactionLineId], references: [id], onDelete: SetNull)

  @@index([inventoryProductId, locationId, batchNo, movementDate])
  @@index([transactionId])
  @@index([transactionLineId])
  @@index([movementType, movementDate])
  @@index([locationId, movementDate])
}

model InventorySerial {
  id                 String               @id @default(cuid())
  inventoryProductId String
  inventoryBatchId   String?
  serialNo           String
  currentLocationId  String?
  status             InventorySerialStatus @default(IN_STOCK)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  inventoryProduct   InventoryProduct     @relation(fields: [inventoryProductId], references: [id], onDelete: Cascade)
  inventoryBatch     InventoryBatch?      @relation(fields: [inventoryBatchId], references: [id], onDelete: SetNull)
  currentLocation    StockLocation?       @relation("InventorySerialCurrentLocation", fields: [currentLocationId], references: [id], onDelete: SetNull)
  transactionEntries StockTransactionLineSerial[]

  @@unique([inventoryProductId, serialNo])
  @@index([inventoryProductId, currentLocationId, status])
  @@index([inventoryBatchId])
}

model StockTransactionLineSerial {
  id                 String               @id @default(cuid())
  transactionLineId  String
  inventoryProductId String
  inventorySerialId  String?
  inventoryBatchId   String?
  serialNo           String
  createdAt          DateTime             @default(now())

  transactionLine    StockTransactionLine @relation(fields: [transactionLineId], references: [id], onDelete: Cascade)
  inventoryProduct   InventoryProduct     @relation(fields: [inventoryProductId], references: [id], onDelete: Restrict)
  inventorySerial    InventorySerial?     @relation(fields: [inventorySerialId], references: [id], onDelete: SetNull)
  inventoryBatch     InventoryBatch?      @relation(fields: [inventoryBatchId], references: [id], onDelete: SetNull)

  @@unique([transactionLineId, serialNo])
  @@index([inventoryProductId, serialNo])
  @@index([inventorySerialId])
  @@index([inventoryBatchId])
}
